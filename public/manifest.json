{
  "manifest_version": 3,
  "name": "CPA 监控面板",
  "description": "聚合查看 CPA 与账号常用信息的浏览器插件面板。",
  "version": "0.1.1",
  "permissions": [
    "storage",
    "tabs"
  ],
  "icons": {
    "16": "cpa_logo.png",
    "32": "cpa_logo.png",
    "48": "cpa_logo.png",
    "128": "cpa_logo.png"
  },
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CPA 快捷面板",
    "default_icon": {
      "16": "cpa_logo.png",
      "32": "cpa_logo.png",
      "48": "cpa_logo.png",
      "128": "cpa_logo.png"
    }
  }
}
